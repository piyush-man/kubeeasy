# ── Required ─────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── Optional: Docker image ────────────────────────────────────────────────────
# IMAGE_REPO=docker.io/piyushman/kubemanager
# IMAGE_TAG=latest

# ── Optional: Kubernetes storage class ───────────────────────────────────────
# Auto-detected by install.sh. Override here if detection fails.
# Examples:
#   microk8s-hostpath    (MicroK8s)
#   local-path           (K3s)
#   gp2                  (AWS EKS)
#   standard             (GKE, generic)
#   default              (AKS)
#   do-block-storage     (DigitalOcean)
# STORAGE_CLASS=

# ── Optional: Service type ────────────────────────────────────────────────────
# NodePort    — local/on-prem clusters (default)
# LoadBalancer — cloud clusters (EKS, GKE, AKS, DOKS)
# SERVICE_TYPE=NodePort

# ── Optional: Custom kubeconfig path ─────────────────────────────────────────
# Defaults to ~/.kube/config, /etc/kubernetes/admin.conf, or k3s/rke2 paths.
# KUBECONFIG=/path/to/kubeconfig

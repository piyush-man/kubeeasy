# Optional: used by ./deploy/install.sh (repo root). Leave Groq empty to use the UI wizard after install.
# GROQ_API_KEY=your_groq_api_key_here

# Container images (build from repo root: see deploy/README.md)
# BACKEND_IMAGE_REPO=docker.io/piyushman/kubeeasy-api
# FRONTEND_IMAGE_REPO=docker.io/piyushman/kubeeasy-ui
# IMAGE_TAG=latest

# HELM_NAMESPACE=kubeeasy
# HELM_RELEASE=kubeeasy
# STORAGE_CLASS=
# SERVICE_TYPE=NodePort

# KUBECONFIG=/path/to/kubeconfig
